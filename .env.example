# CDS (ERA5) credentials — get from https://cds.climate.copernicus.eu/
CDSAPI_URL=https://cds.climate.copernicus.eu/api/v2
CDSAPI_KEY=your-uid:your-api-key

# ECMWF MARS credentials (optional, for operational users only)
ECMWF_API_URL=https://api.ecmwf.int/v1
ECMWF_API_KEY=your-api-key
ECMWF_API_EMAIL=your@email.com
